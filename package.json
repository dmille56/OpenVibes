{
  "name": "@dmille56/openvibes",
  "version": "0.1.9",
  "type": "module",
  "description": "OpenVibes Pi extension for milli-powered terminal overlays.",
  "keywords": [
    "pi-package",
    "openvibes",
    "milli",
    "overlay"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "files": [
    "extensions",
    "images/**/*.milli",
    "sounds/**/*",
    "README.md",
    "PROJECT_SPECS.md"
  ],
  "scripts": {
    "start": "pi --extension ./extensions/openvibes/index.ts",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "xo; echo EXIT:$?",
    "lint-fix": "xo --fix",
    "format": "prettier --write .",
    "check": "npm run typecheck && npm run lint",
    "release": "npm run check && npm version patch && npm publish --access public",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@amansingh-afk/milli": "0.0.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "3.7.4",
    "typescript": "^5.8.0",
    "xo": "^2.0.2"
  },
  "xo": {
    "space": true,
    "prettier": true,
    "rules": {
      "import-x/extensions": "off",
      "function-paren-newline": "off",
      "@stylistic/object-curly-newline": "off",
      "@stylistic/operator-linebreak": "off",
      "@stylistic/multiline-ternary": "off",
      "@stylistic/arrow-parens": "off",
      "@stylistic/function-paren-newline": "off",
      "@stylistic/curly-newline": "off",
      "capitalized-comments": "off",
      "complexity": "off",
      "max-lines-per-function": "off",
      "max-lines": "off",
      "max-params": "off",
      "require-unicode-regexp": "off",
      "unicorn/no-abusive-eslint-disable": "off",
      "n/prefer-global/process": "off",

      "import-x/no-anonymous-default-export": "off",
      "unicorn/no-anonymous-default-export": "off",

      "@typescript-eslint/member-ordering": "off",
      "@typescript-eslint/naming-convention": "off",
      "@typescript-eslint/consistent-type-definitions": "off",
      "@typescript-eslint/strict-void-return": "off",

      "@typescript-eslint/no-misused-promises": "off",
      "@typescript-eslint/no-unsafe-assignment": "off",
      "@typescript-eslint/no-unsafe-argument": "off",
      "@typescript-eslint/no-unsafe-call": "off",
      "@typescript-eslint/no-unsafe-type-assertion": "off",
      "@typescript-eslint/prefer-nullish-coalescing": "off",
      "@typescript-eslint/restrict-template-expressions": "off",

      "no-await-in-loop": "off",
      "no-bitwise": "off",

      "unicorn/no-array-sort": "off",
      "unicorn/prefer-math-trunc": "off",
      "unicorn/prefer-spread": "off",

      "@stylistic/padding-line-between-statements": "off"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmille56/OpenVibes.git"
  },
  "homepage": "https://github.com/dmille56/OpenVibes#readme",
  "bugs": {
    "url": "https://github.com/dmille56/OpenVibes/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
